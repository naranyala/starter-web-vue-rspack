# Set default behavior to automatically normalize line endings
* text=auto

# Source code files should use LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Shell scripts should use LF
*.sh text eol=lf
*.bash text eol=lf

# Config files should use LF
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.eslintrc* text eol=lf
.prettierrc* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
