{
  "name": "rustwebui-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "rspack serve --config rspack.config.dev.mjs",
    "build": "rspack build --config rspack.config.prod.mjs",
    "build:incremental": "rspack build --config rspack.config.mjs",
    "preview": "rspack serve --config rspack.config.prod.mjs",
    "clean": "rm -rf dist && rm -rf node_modules/.cache",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src",
    "format:fix": "biome format src --write",
    "check": "biome check src",
    "check:fix": "biome check src --write",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "ci": "bun run check && bun run test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "pinia": "^2.3.0",
    "winbox": "^0.2.82"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@rspack/cli": "^1.7.5",
    "@rspack/core": "^1.7.5",
    "@rspack/plugin-html": "^0.5.8",
    "@vue/compiler-sfc": "^3.5.0",
    "rspack-vue-loader": "^17.5.0",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
